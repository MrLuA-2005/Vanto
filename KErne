name: Build Vantom Kernel
on:
  workflow_dispatch: # Allows you to start the build manually

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Build Tools
        run: |
          sudo apt update
          sudo apt install -y bc bison build-essential flex git-lfs libssl-dev libelf-dev clang lld llvm

      - name: Clone Vantom Kernel
        run: |
          git clone https://github.com/vantoman/kernel_xiaomi_sm6150.git -b 14 kernel_source
          cd kernel_source

      - name: Integrate KernelSU-Next & SUSFS
        run: |
          cd kernel_source
          # 1. Install KSUN
          curl -LSs "https://raw.githubusercontent.com/KernelSU-Next/KernelSU-Next/main/kernel/setup.sh" | bash -
          
          # 2. Apply SUSFS Patch (AI Note: Using 4.14 legacy patch for Sweet)
          # We'll use a pre-patched SUSFS script for ease
          git clone https://gitlab.com/simonpunk/susfs4ksu.git
          cp susfs4ksu/kernel_patches/50_add_susfs_in_kernel-4.14.patch .
          patch -p1 < 50_add_susfs_in_kernel-4.14.patch
          
          # 3. Add Config Flags
          echo "CONFIG_KSU=y" >> arch/arm64/configs/vendor/sweet_user_defconfig
          echo "CONFIG_KSU_SUSFS=y" >> arch/arm64/configs/vendor/sweet_user_defconfig

      - name: Build Kernel
        run: |
          cd kernel_source
          export ARCH=arm64
          export CROSS_COMPILE=aarch64-linux-gnu-
          make O=out vendor/sweet_user_defconfig
          make -j$(nproc) O=out CC=clang

      - name: Upload Kernel Image
        uses: actions/upload-artifact@v4
        with:
          name: Vantom-KSUN-SUSFS-Image
          path: kernel_source/out/arch/arm64/boot/Image.gz-dtb
